{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "title",
    "content",
    "labels",
    "branch",
    "due_at"
  ],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "due_at": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
